ols","document","en_GB","brxsaas","Related products","similar-items","Minotaur","16oz",6,"BodyText","You might also like","\u002Fhelp-and-advice\u002Fclick-and-collect","\u002Fhelp-and-advice\u002Fdelivery","Adhesives & Sealants","Automotive","Bathrooms","Cleaning & Pest Control","Construction & Insulation","Ironmongery","Kitchens","Ladders & Storage","Landscaping","Lighting","Painting & Decorating","Plumbing","Power Tools","Power Tool Accessories","Security","Screws & Fixings","Workwear & Safety","https:\u002F\u002Fwww.toolstation.com\u002Fapi","Minotaur Ball Pein Hammer 16oz","minotaur-ball-pein-hammer",{},{},Array(0),"Each",20,"Motorbike","Catalogue 104",391,Array(0),Array(1),27,"Hammers","Ball Pein Hammer",Array(9),40,Array(0),Array(13),{},Array(0),Array(0),{},{},{},{},"Similar items","PayPal Credit","\u002Fpaypal-credit","Rewards when you shop","https:\u002F\u002Fcdn.toolstation.com\u002Fcontent\u002Ftsclub.svg","5% OFF +","\u002Fclub","On orders over £40","https:\u002F\u002Fcdn.toolstation.com\u002Fcontent\u002FDelivery_web_icon.svg","FREE DELIVERY"," trustpilot","In as little as 5 mins","https:\u002F\u002Fcdn.toolstation.com\u002Fcontent\u002Fcollection_web_icon.svg","CLICK & COLLECT","Same-day delivery via app","https:\u002F\u002Fcdn.toolstation.com\u002Fcontent\u002FFT_truck.svg","FAST TRACK","\u002Ffast-track-delivery",5,3,2,"GOOGLE","Central Heating Supplies","Smart Home","Ventilation & Heating","Wallpaper Adhesive","Tile Adhesive & Grout","\u002Fpainting-decorating\u002Ftile-adhesive-grout\u002Fc355","Masking Tape","Pressure Washers",10,"Card Payment Readers","\u002Felectrical-supplies-accessories\u002Fcard-payment-readers\u002Fc1448","Multi Tools","Window Hardware","\u002Fironmongery\u002Fwindow-hardware\u002Fc409","Wheels & Castors","\u002Fironmongery\u002Fwheels-castors\u002Fc336","Hooks & Picture Hanging","\u002Fironmongery\u002Fhooks-picture-hanging\u002Fc158","Under Cabinet Spotlights","Under Cabinet Strip Lights","Track Lights","Spotlights","\u002